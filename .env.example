# Environment Variables — copy to .env and fill in values
# Never commit .env to git

# =====================
# LLM Provider
# =====================
# Options: "ollama" (local), "gemini" (cloud), "hf" (HuggingFace free)
LLM_PROVIDER=ollama

# Ollama settings (used when LLM_PROVIDER=ollama)
OLLAMA_MODEL=llama3.2
OLLAMA_BASE_URL=http://localhost:11434

# Gemini settings (used when LLM_PROVIDER=gemini)
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_MODEL=gemini-2.5-flash-lite

# HuggingFace LLM settings (used when LLM_PROVIDER=hf)
HF_LLM_MODEL=Qwen/Qwen2.5-7B-Instruct

# NVIDIA LLM settings (used when LLM_PROVIDER=nvidia)
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_MODEL=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning
NVIDIA_TOP_P=0.95
NVIDIA_MAX_TOKENS=4096

# =====================
# Embedding Model
# =====================
# Uses Qwen3-Embedding-8B (4096-dim) via HuggingFace API
HUGGINGFACEHUB_API_TOKEN=your_hf_token_here

# =====================
# ChromaDB
# =====================
CHROMA_DB_PATH=./data/chroma_db
CHROMA_COLLECTION=mortgage_docs

# =====================
# Chunking
# =====================
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# =====================
# API Settings
# =====================
UPLOAD_DIR=./data/uploaded_pdfs
LLM_TEMPERATURE=0.0
API_HOST=0.0.0.0
API_PORT=8000

# =====================
# Retriever Settings
# =====================
# Multi-query: generate N reformulated queries for better recall
MULTI_QUERY_ENABLED=true
MULTI_QUERY_N=3

# Cross-encoder reranking after RRF fusion
RERANK_ENABLED=true

# =====================
# Logging
# =====================
# Options: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# =====================
# Supabase (Auth + Database + Storage)
# =====================
# Project Settings → API → Project URL
SUPABASE_URL=https://your-project-ref.supabase.co

# anon/public key — safe for frontend
SUPABASE_ANON_KEY=your_anon_key_here

# service_role key — backend ONLY, never expose to frontend
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Storage bucket name
SUPABASE_STORAGE_BUCKET=documents

# =====================
# App
# =====================
FRONTEND_URL=http://localhost:3000
