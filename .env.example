# ════════════════════════════════════════════════════════════════════════
# Supabase Project Settings → API
# ════════════════════════════════════════════════════════════════════════

# Project URL — Settings → API → Project URL
SUPABASE_URL=https://your-project-ref.supabase.co

# anon/public key — used by frontend, safe to expose in browser
SUPABASE_ANON_KEY=your_anon_key_here

# service_role key — used ONLY by backend, NEVER expose to frontend/browser
# Settings → API → service_role secret
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ════════════════════════════════════════════════════════════════════════
# Google OAuth (configured inside Supabase Dashboard → Authentication → Providers)
# These are set in the Supabase Dashboard, NOT in this .env —
# listed here for reference only.
# ════════════════════════════════════════════════════════════════════════
# GOOGLE_CLIENT_ID=...
# GOOGLE_CLIENT_SECRET=...

# ════════════════════════════════════════════════════════════════════════
# Storage
# ════════════════════════════════════════════════════════════════════════
SUPABASE_STORAGE_BUCKET=documents

# ════════════════════════════════════════════════════════════════════════
# App
# ════════════════════════════════════════════════════════════════════════
API_HOST=0.0.0.0
API_PORT=8001
FRONTEND_URL=http://localhost:3000
