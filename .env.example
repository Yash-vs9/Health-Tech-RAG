# Environment Variables — copy to .env and fill in values
# Never commit .env to git

# Embedding model (must be same for indexing AND querying)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ChromaDB persistent storage path
CHROMA_DB_PATH=./data/chroma_db

# ChromaDB collection name
CHROMA_COLLECTION=health_docs

# Upload directory for PDFs
UPLOAD_DIR=./data/uploaded_pdfs

# LLM settings
LLM_TEMPERATURE=0.0

# Groq API (used by Aryan's retriever - src/rag/retriever.py)
GROQ_API_KEY=your_groq_api_key_here

# API settings
API_HOST=0.0.0.0
API_PORT=8000
