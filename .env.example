# Environment Variables — copy to .env and fill in values
# Never commit .env to git

# =====================
# LLM Provider
# =====================
# Options: "ollama" (local) or "gemini" (cloud)
LLM_PROVIDER=ollama

# Ollama settings (used when LLM_PROVIDER=ollama)
OLLAMA_MODEL=llama3.2
OLLAMA_BASE_URL=http://localhost:11434

# Gemini settings (used when LLM_PROVIDER=gemini)
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_MODEL=gemini-2.5-flash-lite

# =====================
# Embedding Model
# =====================
# Options: "local" (MiniLM-L6-v2) or "api" (Qwen3-Embedding-8B via HuggingFace)
EMBEDDING_PROVIDER=local

# Local embedding model (used when EMBEDDING_PROVIDER=local)
LOCAL_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# HuggingFace API embedding (used when EMBEDDING_PROVIDER=api)
HUGGINGFACEHUB_API_TOKEN=your_hf_token_here
API_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-8B

# =====================
# ChromaDB
# =====================
CHROMA_DB_PATH=./data/chroma_db
CHROMA_COLLECTION=mortgage_docs

# =====================
# API Settings
# =====================
UPLOAD_DIR=./data/uploaded_pdfs
LLM_TEMPERATURE=0.0
API_HOST=0.0.0.0
API_PORT=8000
